digraph InteractiveApproval {
  graph [
    goal="Require explicit human approval before deployment",
    label="Interactive Approval"
  ]

  start [shape=Mdiamond, label="Start"]
  approval [shape=hexagon, label="Choose deployment action"]
  deploy [shape=parallelogram, tool_command="echo deploy-approved"]
  reject_exit [shape=Msquare, label="Rejected"]
  done [shape=Msquare, label="Done"]

  start -> approval
  approval -> deploy [label="[A] Approve"]
  approval -> reject_exit [label="[R] Reject"]
  deploy -> done
}
