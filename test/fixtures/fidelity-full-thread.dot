digraph fidelity_full_thread {
  graph [goal="Test full fidelity thread reuse"]

  start [shape=mdiamond]
  plan [shape=box, prompt="Create a plan", fidelity="full", thread_id="feature"]
  implement [shape=box, prompt="Implement the plan", fidelity="full", thread_id="feature"]
  review [shape=box, prompt="Review the implementation", fidelity="full", thread_id="feature"]
  done [shape=msquare]

  start -> plan
  plan -> implement
  implement -> review
  review -> done
}
