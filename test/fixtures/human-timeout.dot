digraph HumanTimeout {
  start [shape=Mdiamond, label="Start"]
  gate [shape=hexagon, label="Continue?", timeout="2s", "human.default_choice"="skip"]
  work [shape=parallelogram, label="Work", script="echo working"]
  skip [shape=parallelogram, label="Skip", script="echo skipped"]
  done [shape=Msquare, label="Done"]

  start -> gate
  gate -> work [label="continue"]
  gate -> skip [label="skip"]
  work -> done
  skip -> done
}
