digraph HumanGate {
  start [shape=Mdiamond, label="Start"]
  approval [shape=hexagon, label="Approve deployment?"]
  deploy [shape=parallelogram, label="Deploy", script="echo deploying"]
  reject [shape=parallelogram, label="Reject", script="echo rejected"]
  done [shape=Msquare, label="Done"]

  start -> approval
  approval -> deploy [label="[A] Approve"]
  approval -> reject [label="[R] Reject"]
  deploy -> done
  reject -> done
}
