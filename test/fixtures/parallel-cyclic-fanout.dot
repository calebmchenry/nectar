digraph CyclicFanOut {
    graph [label="Cyclic double fan-out: tests convergence detection with loop-back edges"]
    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Done"]

    gate [shape=parallelogram, label="Gate", script="echo gate"]

    fan_out_1 [shape=component, label="Fan Out 1", join_policy="wait_all"]
    fan_in_1  [shape=tripleoctagon, label="Fan In 1"]

    branch_a [shape=parallelogram, label="Branch A", script="echo branch_a"]
    branch_b [shape=parallelogram, label="Branch B", script="echo branch_b"]

    fan_out_2 [shape=component, label="Fan Out 2", join_policy="wait_all"]
    fan_in_2  [shape=tripleoctagon, label="Fan In 2"]

    branch_c [shape=parallelogram, label="Branch C", script="echo branch_c"]
    branch_d [shape=parallelogram, label="Branch D", script="exit 1"]

    post [shape=parallelogram, label="Post", script="echo post"]

    start -> gate
    gate -> fan_out_1
    fan_out_1 -> branch_a
    fan_out_1 -> branch_b
    branch_a -> fan_in_1
    branch_b -> fan_in_1
    fan_in_1 -> fan_out_2
    fan_out_2 -> branch_c
    fan_out_2 -> branch_d
    branch_c -> fan_in_2
    branch_d -> fan_in_2
    fan_in_2 -> post
    post -> exit          [label="Done", condition="outcome=success"]
    post -> gate          [label="Loop", condition="outcome=fail"]
    post -> gate          [label="Fallback"]
}
