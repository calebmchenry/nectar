digraph ConditionalBranch {
  start [shape=Mdiamond, label="Start"]
  branch [
    shape=parallelogram,
    label="Branch",
    script="node scripts/compliance_loop.mjs audit"
  ]
  success [shape=parallelogram, label="Success", script="echo success"]
  fail [shape=parallelogram, label="Fail", script="echo fail"]
  done [shape=Msquare, label="Done"]

  start -> branch
  branch -> success [condition="outcome=success"]
  branch -> fail [condition="outcome=fail"]
  branch -> fail [label="Fallback"]
  success -> done
  fail -> done
}
