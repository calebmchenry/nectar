digraph RetryFailureRouting {
  start [shape=Mdiamond]
  unstable [
    shape=parallelogram,
    script="exit 2",
    max_retries="1",
    retry_target="recover"
  ]
  recover [shape=parallelogram, script="echo recover"]
  done [shape=Msquare]

  start -> unstable
  unstable -> done [label="Fallback"]
  recover -> done
}
