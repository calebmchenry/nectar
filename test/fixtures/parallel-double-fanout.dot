digraph DoubleFanOut {
    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Done"]

    fan_out_1 [shape=component, label="Fan Out 1", join_policy="wait_all"]
    fan_in_1  [shape=tripleoctagon, label="Fan In 1"]

    branch_a [shape=parallelogram, label="Branch A", script="echo branch_a"]
    branch_b [shape=parallelogram, label="Branch B", script="echo branch_b"]
    branch_c [shape=parallelogram, label="Branch C", script="echo branch_c"]

    middle [shape=parallelogram, label="Middle", script="echo middle"]

    fan_out_2 [shape=component, label="Fan Out 2", join_policy="wait_all"]
    fan_in_2  [shape=tripleoctagon, label="Fan In 2"]

    branch_d [shape=parallelogram, label="Branch D", script="echo branch_d"]
    branch_e [shape=parallelogram, label="Branch E", script="echo branch_e"]
    branch_f [shape=parallelogram, label="Branch F", script="echo branch_f"]

    start -> fan_out_1
    fan_out_1 -> branch_a
    fan_out_1 -> branch_b
    fan_out_1 -> branch_c
    branch_a -> fan_in_1
    branch_b -> fan_in_1
    branch_c -> fan_in_1
    fan_in_1 -> middle
    middle -> fan_out_2
    fan_out_2 -> branch_d
    fan_out_2 -> branch_e
    fan_out_2 -> branch_f
    branch_d -> fan_in_2
    branch_e -> fan_in_2
    branch_f -> fan_in_2
    fan_in_2 -> exit
}
